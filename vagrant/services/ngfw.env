DEV_MODE=true
DEV_OVERRIDE_POLICY="match ip_ver {
    =v4: match protocol {
		|(=icmp =tcp =udp): verdict allow
    }
    = v6: verdict drop
}"
SSL_INSPECTION_ENABLED=true
MITM_LISTEN_ADDR=0.0.0.0:8443
ML_ENABLED=true
ML_MODEL_PATH=/resources/ngfw/ml/raptorgate-cicids2017-v4-focal.onnx
ML_MODEL_METADATA_PATH=/resources/ngfw/ml/raptorgate-cicids2017-v4-focal.onnx.json

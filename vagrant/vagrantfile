# -*- mode: ruby -*-
# vi: set ft=ruby :

def configure_interface(iface, ip, mask, gateway = nil)
  <<-SHELL
    sudo ip link set #{iface} up
    sudo ip addr add #{ip}/#{mask} dev #{iface}
    #{gateway ? "ip route del default 2>/dev/null || true\nip route add default via #{gateway}" : ""}
  SHELL
end

def setup_tun_device
  <<-SHELL
    modprobe tun
    mkdir -p /dev/net
    if [ ! -c /dev/net/tun ]; then
      mknod /dev/net/tun c 10 200
      chmod 600 /dev/net/tun
    fi
    if ! ip link show tun0 >/dev/null 2>&1; then
      ip tuntap add dev tun0 mode tun
    fi
    ip addr add 10.254.254.1/24 dev tun0 2>/dev/null
    ip link set dev tun0 up
  SHELL
end

def setup_nftables
  <<-SHELL
    apt-get update
    apt-get install -y nftables
    systemctl enable nftables
    systemctl restart nftables

    nft flush ruleset
    nft add table inet filter

    nft 'add chain inet filter input   { type filter hook input   priority 0; policy drop; }'
    nft 'add chain inet filter forward { type filter hook forward priority 0; policy drop; }'
    nft 'add chain inet filter output  { type filter hook output  priority 0; policy accept; }'

    # NOTE: tun0 rules are added in setup_ngfw_service, after the
    # service starts and tun0 has its final interface index.

    # Userspace DNAT publishes TCP/8080 on r1's eth2 address (192.168.20.254),
    # but the Linux local TCP stack must not see that traffic. If INPUT accepts
    # it, the kernel treats it as a local connection and eventually sends RSTs,
    # breaking the userspace-forwarded session.
    nft insert rule inet filter input iifname "eth2" ip daddr 192.168.20.254 tcp dport 8080 drop

    # Allow loopback, established/related connections, and SSH access to the VM
    nft add rule inet filter input iif lo accept
    nft add rule inet filter input ct state established,related accept
    nft add rule inet filter input tcp dport 22 ct state new accept
    nft add rule inet filter input tcp dport 2201 ct state new accept
  SHELL
end
def setup_backend_service
  <<-SHELL
    chmod +x /resources/backend/bun
    cp -f /resources/services/backend.service /etc/systemd/system/backend.service
    systemctl daemon-reload
    systemctl enable backend
    systemctl restart backend
  SHELL
end

def setup_ngfw_service
  <<-SHELL
    sysctl -w net.ipv4.ip_forward=1
    echo "net.ipv4.ip_forward=1" >> /etc/sysctl.conf

    sysctl -w net.ipv4.conf.all.rp_filter=0
    sysctl -w net.ipv4.conf.default.rp_filter=0
    sysctl -w net.ipv4.conf.tun0.1_filter=0
    sysctl -w net.ipv4.conf.eth1.rp_filter=0
    sysctl -w net.ipv4.conf.eth2.rp_filter=0
    sysctl -w net.ipv4.conf.all.accept_local=1
    sysctl -w net.ipv4.conf.tun0.accept_local=1
    sysctl -w net.ipv4.conf.eth2.accept_local=1

    mkdir -p /resources/ngfw
    mkdir -p /resources/ngfw/.data
    mkdir -p /resources/ngfw/sockets
    chmod +x /resources/ngfw/ngfw
    cp -rf /resources/services/* /etc/systemd/system/
    systemctl daemon-reload
    systemctl restart ngfw
    systemctl enable --now ngfw

    # tun0 now has its final index — safe to write nftables rules by name
    nft add rule inet filter forward iif "tun0" accept
    nft add rule inet filter forward oif "tun0" accept
  SHELL
end
unless File.respond_to?(:exists?)
  class << File
    def exists?(path)
      warn "File.exists? is deprecated; use File.exist? instead." unless ENV['SUPPRESS_FILE_EXISTS_WARNING']
      exist?(path)
    end
  end
end

Vagrant.configure("2") do |config|
  config.vagrant.plugins = "vagrant-libvirt"
  # config.vbguest.auto_update = true
  config.vm.box = "bento/ubuntu-24.04"

  config.vm.provider "libvirt" do |lv|
    lv.memory = 1024
    lv.cpus   = 2
    lv.uri = "qemu:///system"
  end
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # ---------------------------------------------------------------
  # Network layout:
  #   192.168.10.0/24  (intnet1) : h1  (.10)  — r1 (.254)
  #   192.168.20.0/24  (intnet2) : h2  (.10)  — r1 (.254)
  #                                             ldap  (.20)
  #                                             radius (.30)
  #   r1 also runs the backend API (internal only, port 3000)
  # ---------------------------------------------------------------

  # --- Host 1 (subnet 1) ----------------------------------------
  config.vm.define "h1" do |h1|
    h1.vm.hostname = "h1"
    h1.vm.network "private_network",
      ip: "192.168.10.10",
      netmask: "255.255.255.0",
      libvirt__network_name: "intnet1"

    h1.vm.provision "shell", inline: "apt-get update -qq && apt-get install -y --no-install-recommends hping3 python3 ncat ethtool python3-scapy"

    h1.vm.provision "shell", inline: configure_interface("eth1", "192.168.10.10", "24", "192.168.10.254") + <<-SHELL
    ip route del default 2>/dev/null || true
    ip route add default via 192.168.10.254
    ethtool -K eth1 tx off
    SHELL
  end

  # --- Host 2 (subnet 2) ----------------------------------------
  config.vm.define "h2" do |h2|
    h2.vm.hostname = "h2"
    h2.vm.network "private_network",
      ip: "192.168.20.10",
      netmask: "255.255.255.0",
      libvirt__network_name: "intnet2"

    h2.vm.provision "shell", inline: "apt-get update -qq && apt-get install -y --no-install-recommends hping3 python3 ncat ethtool python3-scapy python3-pyftpdlib"

    h2.vm.provision "shell", inline: configure_interface("eth1", "192.168.20.10", "24", "192.168.20.254") + <<-SHELL
    ip route del default 2>/dev/null || true
    ip route add default via 192.168.20.254
    ethtool -K eth1 tx off
    SHELL
  end

  # --- Router (between both subnets) + Backend API -------------
  config.vm.define "r1" do |r1|
    r1.vm.hostname = "r1"
    r1.vm.network "private_network",
      ip: "192.168.10.254",
      netmask: "255.255.255.0",
      libvirt__network_name: "intnet1"
    r1.vm.network "private_network",
      ip: "192.168.20.254",
      netmask: "255.255.255.0",
      libvirt__network_name: "intnet2"

    # config.trigger.before :provision do |t|
    #   t.info = "rsyncing .router_sync -> /resources"
    #   t.run = { inline: "vagrant rsync r1" }
    # end

    r1.vm.synced_folder ".router_sync", "/resources", id: "ngfw", type: "rsync"

    r1.vm.provision "shell", inline:
      configure_interface("eth1", "192.168.10.254", "24") +
      configure_interface("eth2", "192.168.20.254", "24") +
      setup_tun_device + setup_nftables + setup_ngfw_service + setup_backend_service

    # r1 has two interfaces, no gateway needed since it IS the gateway
  end

  config.vm.define "ldap" do |ldap|
    ldap.vm.hostname = "ldap"
    ldap.vm.network "private_network",
      ip: "192.168.20.40",
      netmask: "255.255.255.0",
      libvirt__network_name: "intnet2"

    ldap.vm.provision "file",
      source: "scripts/seed.ldif",
      destination: "/tmp/seed.ldif"


    ldap.vm.provision "shell", path: "scripts/provision-ldap.sh"
    ldap.vm.provision "shell", inline: configure_interface("eth1", "192.168.20.40", "24", "192.168.20.254") + <<-SHELL
      # ip route del default 2>/dev/null || true
      # ip route add default via 192.168.20.254
    SHELL
  end

  config.vm.define "radius" do |radius|
    radius.vm.hostname = "radius"
    radius.vm.network "private_network",
      ip: "192.168.20.30",
      netmask: "255.255.255.0",
      libvirt__network_name: "intnet2"

    radius.vm.provision "shell", path: "scripts/provision-radius.sh"

    radius.vm.provision "shell", inline: configure_interface("eth1", "192.168.20.30", "24", "192.168.20.254") + <<-SHELL
      ip route del default 2>/dev/null || true
      ip route add default via 192.168.20.254
    SHELL
  end
end

# -*- mode: ruby -*-
# vi: set ft=ruby :

def setup_tun_device
  <<-SHELL
    modprobe tun
    mkdir -p /dev/net
    if [ ! -c /dev/net/tun ]; then
      mknod /dev/net/tun c 10 200
      chmod 600 /dev/net/tun
    fi
    if ! ip link show tun0 >/dev/null 2>&1; then
      ip tuntap add dev tun0 mode tun
    fi
    ip addr add 10.254.254.1/24 dev tun0 2>/dev/null
    ip link set dev tun0 up
  SHELL
end

def setup_nftables
  <<-SHELL
    apt-get update
    apt-get install -y nftables
    systemctl enable nftables
    systemctl restart nftables

    nft flush ruleset
    nft add table inet filter

    # INPUT:  drop everything unless explicitly allowed
    # FORWARD: drop everything — force all forwarding through tun0 (our NGFW app)
    #          Without this, the kernel would forward packets directly between
    #          enp0s8 and enp0s9, completely bypassing our application.
    # OUTPUT:  accept — the router must be able to send packets (ARP, forwarded from tun0, etc.)
    nft 'add chain inet filter input   { type filter hook input   priority 0; policy drop; }'
    nft 'add chain inet filter forward { type filter hook forward priority 0; policy drop; }'
    nft 'add chain inet filter output  { type filter hook output  priority 0; policy accept; }'

    # Allow forwarding ONLY from/to tun0.
    # Traffic flow: enp0s8/9 -> pcap capture -> NGFW app -> tun0 -> kernel forward -> enp0s8/9
    # Direct forward between physical interfaces (enp0s8 <-> enp0s9) stays BLOCKED.
    nft add rule inet filter forward iif "tun0" accept
    nft add rule inet filter forward oif "tun0" accept

    # Allow loopback, established/related connections, and SSH access to the VM
    nft add rule inet filter input iif lo accept
    nft add rule inet filter input ct state established,related accept
    nft add rule inet filter input tcp dport 22 ct state new accept
    nft add rule inet filter input tcp dport 2201 ct state new accept
  SHELL
end

def setup_postgres
  <<-SHELL
    apt-get update -qq
    apt-get install -y --no-install-recommends postgresql postgresql-contrib

    systemctl enable postgresql
    systemctl start postgresql

    # Create database and user
    sudo -u postgres psql -tc "SELECT 1 FROM pg_roles WHERE rolname='raptorgate'" | grep -q 1 || \
      sudo -u postgres psql -c "CREATE USER raptorgate WITH PASSWORD 'raptorgate';"
    sudo -u postgres psql -tc "SELECT 1 FROM pg_database WHERE datname='raptorgate'" | grep -q 1 || \
      sudo -u postgres psql -c "CREATE DATABASE raptorgate OWNER raptorgate;"

    # Allow connections from localhost only (default pg_hba.conf is fine)
    echo "=== PostgreSQL setup complete ==="
    echo "Host: localhost:5432"
    echo "Database: raptorgate"
    echo "User: raptorgate / raptorgate"
  SHELL
end

def setup_redis
  <<-SHELL
    apt-get update -qq
    apt-get install -y --no-install-recommends redis-server

    systemctl enable redis-server
    systemctl restart redis-server

    echo "=== Redis setup complete ==="
    echo "Host: localhost:6379"
  SHELL
end

def setup_ngfw_service
  <<-SHELL
    sysctl -w net.ipv4.ip_forward=1
    echo "net.ipv4.ip_forward=1" >> /etc/sysctl.conf

    # Disable reverse path filtering on tun0.
    # Without this, the kernel drops packets arriving on tun0 whose source IP
    # (e.g. 192.168.1.10) has a route through a different interface (enp0s8).
    # rp_filter checks: "would I route a reply back through the same interface
    # this packet arrived on?" — for tun0 the answer is always no, so it drops.
    sysctl -w net.ipv4.conf.all.rp_filter=0
    sysctl -w net.ipv4.conf.default.rp_filter=0
    sysctl -w net.ipv4.conf.tun0.rp_filter=0

    mkdir -p /resources/ngfw
    # cp -rf /opt/ngfw/bin/Debug/net10.0/linux-x64/* /resources/ngfw
    chmod +x /resources/ngfw/ngfw
    # setcap cap_net_raw+ep /resources/ngfw/ngfw
    cp -rf /resources/services/* /etc/systemd/system/
    systemctl daemon-reload
    systemctl restart ngfw
    systemctl enable --now ngfw
    # /resources/ngfw/ngfw &
  SHELL
end

unless File.respond_to?(:exists?)
  class << File
    def exists?(path)
      warn "File.exists? is deprecated; use File.exist? instead." unless ENV['SUPPRESS_FILE_EXISTS_WARNING']
      exist?(path)
    end
  end
end

Vagrant.configure("2") do |config|
  # config.vbguest.auto_update = true
  config.vm.box = "ubuntu/jammy64"

  config.vm.provider "virtualbox" do |vb|
    vb.memory = 1024
    vb.cpus   = 2
  end

  # ---------------------------------------------------------------
  # Network layout:
  #   192.168.1.0/24  (intnet1) : h1  (.10)  — r1 (.254)
  #   192.168.2.0/24  (intnet2) : h2  (.10)  — r1 (.254)
  #                                             ldap  (.20)
  #                                             radius (.30)
  #   r1 also runs the backend API (internal only, port 3000)
  # ---------------------------------------------------------------

  # --- Host 1 (subnet 1) ----------------------------------------
  config.vm.define "h1" do |h1|
    h1.vm.hostname = "h1"
    h1.vm.network "private_network",
      ip: "192.168.1.10",
      netmask: "255.255.255.0",
      virtualbox__intnet: "intnet1"

    h1.vm.provision "shell", inline: <<-SHELL
    ip route del default 2>/dev/null || true
    ip route add default via 192.168.1.254
    SHELL
  end

  # --- Host 2 (subnet 2) ----------------------------------------
  config.vm.define "h2" do |h2|
    h2.vm.hostname = "h2"
    h2.vm.network "private_network",
      ip: "192.168.2.10",
      netmask: "255.255.255.0",
      virtualbox__intnet: "intnet2"

    h2.vm.provision "shell", inline: <<-SHELL
    ip route del default 2>/dev/null || true
    ip route add default via 192.168.2.254
    SHELL
  end

  # --- Router (between both subnets) + Backend API -------------
  config.vm.define "r1" do |r1|
    r1.vm.hostname = "r1"
    r1.vm.network "private_network",
      ip: "192.168.1.254",
      netmask: "255.255.255.0",
      virtualbox__intnet: "intnet1"
    r1.vm.network "private_network",
      ip: "192.168.2.254",
      netmask: "255.255.255.0",
      virtualbox__intnet: "intnet2"

    r1.vm.synced_folder ".router_sync", "/resources", id: "ngfw"

    r1.vm.provision "shell", inline: setup_tun_device + setup_nftables + setup_ngfw_service
  end

end
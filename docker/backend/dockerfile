ARG PROJECT_NAME=raptor-gate_backend

FROM oven/bun:1 AS build
ARG PROJECT_NAME
ENV PROJECT_NAME=${PROJECT_NAME}
WORKDIR /usr/src/${PROJECT_NAME}

RUN apt-get update && apt-get install -y --no-install-recommends curl unzip ca-certificates \
 && curl -fsSL https://github.com/protocolbuffers/protobuf/releases/download/v29.3/protoc-29.3-linux-x86_64.zip -o /tmp/protoc.zip \
 && unzip /tmp/protoc.zip -d /usr/local \
 && rm /tmp/protoc.zip

COPY backend/package.json backend/bun.lock ./
RUN bun install --frozen-lockfile

COPY backend/src ./src
COPY backend/scripts ./scripts
COPY backend/drizzle ./drizzle
COPY backend/tsconfig.json backend/tsconfig.build.json backend/nest-cli.json backend/drizzle.config.ts ./
COPY proto /usr/src/proto

RUN bun scripts/generate-proto.ts
# RUN bun test
RUN bun run build
RUN DATABASE_URL=postgresql://dummy:dummy@localhost:5432/dummy bun run db:generate

RUN mkdir -p /build/output/backend \
 && cp -R dist /build/output/backend/dist \
 && cp -R node_modules /build/output/backend/node_modules \
 && cp -R drizzle /build/output/backend/drizzle \
 && cp package.json bun.lock drizzle.config.ts /build/output/backend/ \
 && cp /usr/local/bin/bun /build/output/backend/bun

FROM alpine:3.19 AS runtime
COPY --from=build /build/output/backend /app/backend

CMD ["sh", "-lc", "mkdir -p /host/bin/backend && cp -R /app/backend/. /host/bin/backend/"]
